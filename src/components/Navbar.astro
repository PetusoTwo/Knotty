---
import { Home, Grid, Sparkles, Heart, MessageCircle } from '@lucide/astro';

const navItems = [
{ name: 'Inicio', icon: Home, href: '/', sectionId: 'home' },
{ name: 'Catalogo', icon: Grid, href: '/#catalogo', sectionId: 'catalogo' },
{ name: 'Sobre nosotros', icon: Heart, href: '/#nosotros', sectionId: 'nosotros' },
{ name: 'Contacto', icon: MessageCircle, href: '/#contacto', sectionId: 'contacto' },
];
---

<header class="fixed bottom-6 sm:bottom-auto sm:top-6 left-1/2 -translate-x-1/2 z-50 w-max">
    <nav
        class="bg-[linear-gradient(135deg,rgba(147,47,109,0.72),rgba(66,0,57,0.7))] backdrop-blur-xl border border-white/20 shadow-2xl shadow-primary/20 rounded-3xl p-2 flex gap-1 sm:gap-2 justify-center items-center transition-all duration-300">
        {navItems.map((item, index) => {
        const Icon = item.icon;
        const isActive = index === 0;

        return (
        <a href={item.href} aria-label={item.name} data-nav-link data-section-id={item.sectionId} class={`group relative
            p-3 sm:p-3.5 rounded-2xl transition-all duration-300 flex items-center justify-center focus:outline-none
            ${isActive ? 'bg-white/10 text-white shadow-inner'
            : 'text-white/60 hover:text-white hover:bg-white/5 active:scale-95' }`}>
            <Icon data-nav-icon class={`w-5 h-5 sm:w-6 sm:h-6 transition-all duration-300 ${isActive
                ? 'scale-110 drop-shadow-md text-primary' : 'group-hover:scale-110' }`} />

            <span
                class="pointer-events-none absolute top-[calc(100%+10px)] left-1/2 -translate-x-1/2 px-3 py-1.5 bg-dark/95 backdrop-blur-md text-white text-xs font-medium rounded-xl opacity-0 transition-all duration-300 whitespace-nowrap shadow-lg -translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 hidden sm:block border border-white/10">
                {item.name}
            </span>
        </a>
        );
        })}
    </nav>
</header>

<script>
    const ACTIVE_LINK_CLASSES = ['bg-white/10', 'text-white', 'shadow-inner'];
    const INACTIVE_LINK_CLASSES = ['text-white/60', 'hover:text-white', 'hover:bg-white/5', 'active:scale-95'];
    const ACTIVE_ICON_CLASSES = ['scale-110', 'drop-shadow-md', 'text-primary'];
    const INACTIVE_ICON_CLASSES = ['group-hover:scale-110'];

    const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'));

    const setActiveSection = (sectionId) => {
        navLinks.forEach((link) => {
            const icon = link.querySelector('[data-nav-icon]');
            const isActive = link.dataset.sectionId === sectionId;

            link.classList.remove(...ACTIVE_LINK_CLASSES, ...INACTIVE_LINK_CLASSES);
            icon?.classList.remove(...ACTIVE_ICON_CLASSES, ...INACTIVE_ICON_CLASSES);

            if (isActive) {
                link.classList.add(...ACTIVE_LINK_CLASSES);
                icon?.classList.add(...ACTIVE_ICON_CLASSES);
            } else {
                link.classList.add(...INACTIVE_LINK_CLASSES);
                icon?.classList.add(...INACTIVE_ICON_CLASSES);
            }
        });
    };

    const sections = navLinks
        .map((link) => link.dataset.sectionId)
        .filter((id) => id && id !== 'home')
        .map((id) => document.getElementById(id))
        .filter(Boolean);

    const updateByScroll = () => {
        if (window.scrollY < 120) {
            setActiveSection('home');
            return;
        }

        let current = 'home';
        sections.forEach((section) => {
            const rect = section.getBoundingClientRect();
            if (rect.top <= window.innerHeight * 0.4 && rect.bottom >= window.innerHeight * 0.35) {
                current = section.id;
            }
        });

        setActiveSection(current);
    };

    window.addEventListener('scroll', updateByScroll, { passive: true });
    window.addEventListener('load', updateByScroll);
    updateByScroll();
</script>