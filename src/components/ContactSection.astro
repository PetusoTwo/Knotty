---
import {
  contactContent,
  getBaseWhatsappMessage,
  buildWhatsappUrlFromIdea,
} from "../data/contact";

const baseHref = `https://wa.me/${contactContent.whatsappPhone}?text=${encodeURIComponent(getBaseWhatsappMessage())}`;
const bubbleHrefs = contactContent.floatingIdeas.map((idea) => ({
  idea,
  href: buildWhatsappUrlFromIdea(idea),
}));
---

<section id="contacto" class="relative isolate overflow-hidden px-4 pt-16 pb-20 sm:px-6 sm:pt-20 sm:pb-24 lg:px-10">
  <div class="absolute inset-0 -z-40 bg-[radial-gradient(circle_at_18%_20%,#E07BE030_0%,transparent_40%),radial-gradient(circle_at_80%_18%,#932F6D20_0%,transparent_36%),linear-gradient(165deg,#F6F2FF_0%,#EBDDFF_48%,#F6F2FF_100%)]"></div>
  <div class="pointer-events-none absolute -left-24 top-20 -z-30 h-64 w-64 rounded-full bg-secondary/20 blur-3xl animate-contact-orbit-a"></div>
  <div class="pointer-events-none absolute right-8 top-24 -z-30 h-60 w-60 rounded-full bg-primary/14 blur-3xl animate-contact-orbit-b"></div>
  <div class="pointer-events-none absolute right-[28%] bottom-12 -z-30 h-44 w-44 rounded-full bg-soft/55 blur-3xl animate-contact-orbit-c"></div>

  <div class="mx-auto w-full max-w-6xl">
    <p class="mx-auto w-fit rounded-full border border-primary/20 bg-white/70 px-4 py-1 text-xs uppercase tracking-[0.2em] text-primary shadow-sm">
      {contactContent.eyebrow}
    </p>

    <h2 class="mx-auto mt-5 max-w-4xl text-center text-4xl sm:text-5xl lg:text-6xl leading-[0.95] whitespace-pre-line text-dark">
      {contactContent.title}
    </h2>

    <p class="mx-auto mt-4 max-w-2xl text-center text-base sm:text-lg leading-relaxed text-dark/75">
      {contactContent.subtitle}
    </p>

    <div class="relative mt-8 min-h-[980px] sm:min-h-[920px] lg:min-h-[700px]">
      <svg class="pointer-events-none absolute inset-0 z-0 h-full w-full" viewBox="0 0 1200 760" fill="none" preserveAspectRatio="none" aria-hidden="true">
        <path d="M210 208C330 134 482 154 598 234C714 314 856 304 992 228" stroke="rgba(147,47,109,0.34)" stroke-width="2.8" stroke-linecap="round" stroke-dasharray="7 10" class="contact-thread" />
        <path d="M170 498C324 446 450 458 572 528C692 594 834 594 996 530" stroke="rgba(224,123,224,0.34)" stroke-width="2.8" stroke-linecap="round" stroke-dasharray="6 10" class="contact-thread-delay" />
      </svg>

      <figure class="group absolute left-1/2 top-[120px] z-20 w-[70%] max-w-[380px] -translate-x-1/2 rounded-[2.4rem_1.8rem_2.5rem_2rem] border border-white/70 bg-white/65 p-3 shadow-2xl shadow-primary/15 backdrop-blur-sm transition-all duration-500 hover:-translate-y-2 hover:rotate-[1deg] sm:top-[150px] lg:top-[120px]">
        <img
          src="/images/contact-02.jpg"
          alt="Amigurumi principal del mundo Knotty."
          class="h-[260px] w-full rounded-[1.9rem_1.4rem_2.1rem_1.6rem] object-cover transition-transform duration-700 group-hover:scale-[1.05] sm:h-[320px]"
          style="object-position: 50% 30%;"
          loading="lazy"
        />
      </figure>

      <figure class="group absolute right-[7%] top-[320px] z-20 w-[34%] max-w-[220px] rounded-[1.8rem_1.4rem_2rem_1.6rem] border border-white/70 bg-white/70 p-2.5 shadow-xl transition-all duration-500 hover:-translate-y-1 hover:rotate-2 sm:right-[12%] sm:top-[470px] lg:right-[10%] lg:top-[390px]">
        <img
          src="/images/contact-03.jpg"
          alt="Mini amigurumi decorativo"
          class="h-[130px] w-full rounded-[1.2rem_0.9rem_1.3rem_1rem] object-cover transition-transform duration-700 group-hover:scale-[1.05] sm:h-[150px]"
          style="object-position: 50% 38%;"
          loading="lazy"
        />
      </figure>

      <figure class="group absolute left-[8%] top-[520px] z-20 w-[38%] max-w-[240px] rounded-[2rem_1.5rem_2.1rem_1.7rem] border border-white/70 bg-white/70 p-2.5 shadow-xl transition-all duration-500 hover:-translate-y-1 hover:-rotate-2 sm:left-[12%] sm:top-[610px] lg:left-[12%] lg:top-[420px]">
        <img
          src="/images/contact-04.jpg"
          alt="Mini amigurumi decorativo"
          class="h-[140px] w-full rounded-[1.2rem_1rem_1.3rem_1.1rem] object-cover transition-transform duration-700 group-hover:scale-[1.05] sm:h-[160px]"
          style="object-position: 50% 36%;"
          loading="lazy"
        />
      </figure>

      <a
        href={bubbleHrefs[0].href}
        target="_blank"
        rel="noreferrer"
        class="contact-bubble contact-bubble-a absolute left-[6%] top-[98px] z-30 rounded-[2rem_1.6rem_2rem_1.4rem] border border-white/75 bg-white/80 px-4 py-2 text-sm font-medium text-dark shadow-md backdrop-blur-sm transition-all duration-300 hover:scale-[1.03] hover:rotate-[-1deg] hover:shadow-lg sm:left-[12%] sm:top-[230px]"
      >
        {bubbleHrefs[0].idea}
      </a>

      <a
        href={bubbleHrefs[1].href}
        target="_blank"
        rel="noreferrer"
        class="contact-bubble contact-bubble-b absolute right-[5%] top-[230px] z-30 rounded-[1.8rem_2rem_1.4rem_2rem] border border-white/75 bg-white/80 px-4 py-2 text-sm font-medium text-dark shadow-md backdrop-blur-sm transition-all duration-300 hover:scale-[1.03] hover:rotate-[1deg] hover:shadow-lg sm:right-[10%] sm:top-[320px]"
      >
        {bubbleHrefs[1].idea}
      </a>

      <a
        href={bubbleHrefs[2].href}
        target="_blank"
        rel="noreferrer"
        class="contact-bubble contact-bubble-c absolute left-[10%] top-[700px] z-30 rounded-[2rem_1.5rem_1.9rem_1.7rem] border border-white/75 bg-white/80 px-4 py-2 text-sm font-medium text-dark shadow-md backdrop-blur-sm transition-all duration-300 hover:scale-[1.03] hover:rotate-[1deg] hover:shadow-lg sm:left-[18%] sm:top-[770px] lg:left-[26%] lg:top-[620px]"
      >
        {bubbleHrefs[2].idea}
      </a>

      <a
        href={bubbleHrefs[3].href}
        target="_blank"
        rel="noreferrer"
        class="contact-bubble contact-bubble-d absolute right-[8%] top-[650px] z-30 rounded-[1.7rem_2rem_1.8rem_1.5rem] border border-white/75 bg-white/80 px-4 py-2 text-sm font-medium text-dark shadow-md backdrop-blur-sm transition-all duration-300 hover:scale-[1.03] hover:rotate-[-1deg] hover:shadow-lg sm:right-[12%] sm:top-[710px] lg:right-[24%] lg:top-[560px]"
      >
        {bubbleHrefs[3].idea}
      </a>

      <form
        class="contact-composer absolute left-1/2 top-[790px] z-30 w-[92%] max-w-[520px] -translate-x-1/2 rounded-[1.8rem_2.2rem_1.6rem_2rem] border border-white/75 bg-white/78 p-3 shadow-xl backdrop-blur-sm sm:top-[845px] lg:top-[640px]"
        data-idea-form
      >
        <p class="px-2 text-xs uppercase tracking-[0.16em] text-primary/75">Tu idea en una linea</p>
        <div class="mt-2 flex items-center gap-2 rounded-[1.2rem_1.4rem_1.1rem_1.5rem] border border-primary/20 bg-white/90 p-2">
          <input
            type="text"
            data-idea-input
            placeholder="Ej: Quiero un capibara dormilon 🧸"
            class="w-full border-0 bg-transparent px-2 py-1 text-sm text-dark placeholder:text-dark/45 focus:outline-none"
          />
          <button
            type="submit"
            class="cursor-pointer shrink-0 rounded-full bg-primary px-4 py-2 text-xs font-semibold text-white shadow-md shadow-primary/30 transition-all duration-300 hover:bg-dark"
          >
            Enviar
          </button>
        </div>
      </form>

      <span class="pointer-events-none absolute left-[18%] top-[340px] z-20 text-2xl text-secondary/85 animate-contact-sparkle">✦</span>
      <span class="pointer-events-none absolute right-[20%] top-[520px] z-20 text-xl text-primary/80 animate-contact-sparkle-delay">♡</span>
      <span class="pointer-events-none absolute right-[34%] top-[220px] z-20 text-xl text-secondary/80 animate-contact-sparkle">✧</span>
    </div>
  </div>
</section>

<script define:vars={{ whatsappPhone: contactContent.whatsappPhone, baseMessage: getBaseWhatsappMessage() }}>
  const form = document.querySelector("[data-idea-form]");
  const input = document.querySelector("[data-idea-input]");

  const buildMessage = (ideaText) => {
    const cleanIdea = (ideaText || "").trim();
    if (!cleanIdea) {
      return baseMessage;
    }

    return (
      "Hola! Quiero un amigurumi\n" +
      `Mi idea es: ${cleanIdea}\n\n` +
      "Podrian ayudarme?"
    );
  };

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    const value = input instanceof HTMLInputElement ? input.value : "";
    const text = encodeURIComponent(buildMessage(value));
    window.open(`https://wa.me/${whatsappPhone}?text=${text}`, "_blank", "noopener,noreferrer");
  });
</script>

<style>
  @keyframes contact-orbit-a {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(10px, -8px, 0);
    }
  }

  @keyframes contact-orbit-b {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(-9px, 10px, 0);
    }
  }

  @keyframes contact-orbit-c {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(8px, -7px, 0);
    }
  }

  @keyframes contact-thread-flow {
    0% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: -170;
    }
  }

  @keyframes contact-bubble-float-a {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(6px, -6px, 0);
    }
  }

  @keyframes contact-bubble-float-b {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(-6px, 7px, 0);
    }
  }

  @keyframes contact-sparkle {
    0%,
    100% {
      transform: scale(1) rotate(0deg);
      opacity: 0.68;
    }
    50% {
      transform: scale(1.12) rotate(8deg);
      opacity: 1;
    }
  }

  @keyframes contact-sparkle-delay {
    0%,
    100% {
      transform: scale(1) rotate(0deg);
      opacity: 0.62;
    }
    50% {
      transform: scale(1.1) rotate(-8deg);
      opacity: 1;
    }
  }

  .animate-contact-orbit-a {
    animation: contact-orbit-a 12s ease-in-out infinite;
  }

  .animate-contact-orbit-b {
    animation: contact-orbit-b 13s ease-in-out infinite;
  }

  .animate-contact-orbit-c {
    animation: contact-orbit-c 11s ease-in-out infinite;
  }

  .contact-thread {
    animation: contact-thread-flow 11s linear infinite;
  }

  .contact-thread-delay {
    animation: contact-thread-flow 13s linear infinite reverse;
  }

  .contact-bubble-a,
  .contact-bubble-c {
    animation: contact-bubble-float-a 8s ease-in-out infinite;
  }

  .contact-bubble-b,
  .contact-bubble-d {
    animation: contact-bubble-float-b 9s ease-in-out infinite;
  }

  .animate-contact-sparkle {
    animation: contact-sparkle 4.5s ease-in-out infinite;
  }

  .animate-contact-sparkle-delay {
    animation: contact-sparkle-delay 5s ease-in-out infinite;
  }

  @media (max-width: 1023px) {
    .contact-thread,
    .contact-thread-delay {
      opacity: 0.45;
    }
  }

  @media (max-width: 640px) {
    .contact-bubble {
      font-size: 0.8rem;
      line-height: 1.25rem;
      padding: 0.45rem 0.85rem;
      max-width: 9.6rem;
      text-wrap: balance;
    }

    .contact-composer {
      top: 790px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-contact-orbit-a,
    .animate-contact-orbit-b,
    .animate-contact-orbit-c,
    .contact-thread,
    .contact-thread-delay,
    .contact-bubble-a,
    .contact-bubble-b,
    .contact-bubble-c,
    .contact-bubble-d,
    .animate-contact-sparkle,
    .animate-contact-sparkle-delay {
      animation: none;
    }
  }
</style>
