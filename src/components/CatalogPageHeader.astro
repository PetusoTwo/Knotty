---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Todos nuestros amigurumis",
  subtitle = "Cada pieza esta tejida con cariño para acompañar momentos especiales y regalar ternura.",
} = Astro.props;
---

<section class="relative isolate overflow-hidden px-4 pt-28 pb-12 sm:px-6 sm:pt-32 sm:pb-14 lg:px-10">
  <div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_20%_25%,#E07BE033_0%,transparent_45%),radial-gradient(circle_at_80%_20%,#932F6D22_0%,transparent_40%),linear-gradient(180deg,#F6F2FF_0%,#DCCCFF40_55%,#F6F2FF_100%)]"></div>
  <div class="pointer-events-none absolute -left-16 top-16 -z-10 h-48 w-48 rounded-full bg-secondary/20 blur-3xl"></div>
  <div class="pointer-events-none absolute right-6 top-14 -z-10 h-56 w-56 rounded-full bg-primary/15 blur-3xl"></div>
  <div class="pointer-events-none absolute left-[42%] top-12 -z-10 h-16 w-16 rounded-[56%_44%_63%_37%/47%_45%_55%_53%] border border-primary/15 bg-white/25"></div>

  <div class="mx-auto w-full max-w-5xl text-center">
    <p class="inline-flex items-center rounded-full border border-primary/20 bg-white/70 px-4 py-1 text-xs uppercase tracking-[0.2em] text-primary shadow-sm">
      Coleccion completa
    </p>
    <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl leading-[0.95] text-dark">
      {title} <span class="inline-block">🧸</span>
    </h1>
    <p class="mx-auto mt-4 max-w-3xl text-base sm:text-lg leading-relaxed text-dark/75">
      {subtitle}
    </p>
  </div>
</section>
