---
import { buildProductWhatsAppUrl } from "../data/products";

const { product, index = 0, variant = "normal" } = Astro.props;

const whatsappHref = buildProductWhatsAppUrl(product.nombre);
const accentClass =
index % 3 === 0
? "from-secondary/25 to-soft/25"
: index % 3 === 1
? "from-soft/35 to-background/70"
: "from-secondary/20 to-background/75";
const organicClass =
index % 4 === 0
? "rounded-[2rem_1.4rem_2.2rem_1.6rem]"
: index % 4 === 1
? "rounded-[1.5rem_2.2rem_1.7rem_2rem]"
: index % 4 === 2
? "rounded-[2.1rem_1.7rem_1.5rem_2.3rem]"
: "rounded-[1.7rem_2.1rem_2rem_1.5rem]";
---

<article class={`group relative flex flex-col h-full border border-white/70 bg-white/50 p-3.5 sm:p-4 shadow-md transition-all duration-500
    hover:-translate-y-1.5 hover:shadow-2xl hover:shadow-primary/15 ${organicClass}`}>
    <div class={`pointer-events-none absolute inset-0 -z-10 ${organicClass} bg-gradient-to-br ${accentClass}`}></div>

    <div
        class="relative overflow-hidden rounded-[1.35rem] border border-white/70 bg-primary/5 shadow-sm transition-transform duration-500 group-hover:-translate-y-1 group-hover:rotate-[0.6deg]">

        <!-- Loader / Skeleton -->
        <div class="absolute inset-0 flex items-center justify-center">
            <div class="h-8 w-8 animate-spin rounded-full border-4 border-primary/10 border-t-primary/70"></div>
        </div>

        <img src={product.imagen} alt={`Amigurumi ${product.nombre}`} class="relative z-10 block h-auto w-full object-contain transition-transform duration-700 group-hover:scale-[1.03]"
            loading="lazy" />
            
        <div class="pointer-events-none absolute inset-x-0 bottom-0 z-20 h-16 bg-gradient-to-t from-dark/20 to-transparent">
        </div>
    </div>

    <div class="mt-4 mb-4 flex flex-col flex-grow space-y-2.5">
        <h3 class="text-2xl leading-tight text-dark">{product.nombre}</h3>
        <p class="text-sm leading-relaxed text-dark/75 min-h-[2.5rem] flex-grow">
            {product.descripcion}
        </p>
        <div class="mt-auto pt-1">
            {product.precioUnidad && product.precioDocena ? (
                <div class="flex items-center justify-between text-xs font-semibold tracking-wide text-primary/80">
                    <span>Unidad: {product.precioUnidad}</span>
                    <span>Docena: {product.precioDocena}</span>
                </div>
            ) : (
                <p class="text-xs font-medium tracking-wide text-primary/70">Desde {product.precio}</p>
            )}
        </div>
    </div>

    <a href={whatsappHref} target="_blank" rel="noreferrer"
        class="mt-auto inline-flex w-full items-center justify-center rounded-full bg-primary px-4 py-2.5 text-sm font-semibold text-white shadow-md shadow-primary/30 transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02] hover:bg-dark hover:shadow-lg hover:shadow-primary/30 focus:outline-none focus:ring-2 focus:ring-primary/40">
        {product.cta ?? "Lo quiero 💜"}
    </a>
</article>