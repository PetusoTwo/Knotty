---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
import Footer from "../components/Footer.astro";
import { featuredProducts as allProducts } from "../data/products";
---

<Layout title="Catalogo | Knotty" description="Explora todos los amigurumis de Knotty y pide el tuyo por WhatsApp.">
  <section class="relative isolate overflow-hidden px-4 pt-28 pb-16 sm:px-6 sm:pt-32 sm:pb-20 lg:px-10">
    <div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_18%_18%,#E07BE026_0%,transparent_42%),radial-gradient(circle_at_82%_20%,#932F6D1A_0%,transparent_40%),linear-gradient(180deg,#F6F2FF_0%,#ECE2FF_35%,#DCCCFF40_68%,#F6F2FF_100%)]"></div>
    <div class="pointer-events-none absolute -left-24 top-20 -z-10 h-60 w-60 rounded-full bg-secondary/18 blur-3xl"></div>
    <div class="pointer-events-none absolute right-6 top-32 -z-10 h-56 w-56 rounded-full bg-primary/12 blur-3xl"></div>
    <div class="pointer-events-none absolute right-16 bottom-20 -z-10 h-64 w-64 rounded-full bg-soft/35 blur-3xl"></div>

    <header class="mx-auto w-full max-w-5xl text-center">
      <p class="inline-flex items-center rounded-full border border-primary/20 bg-white/70 px-4 py-1 text-xs uppercase tracking-[0.2em] text-primary shadow-sm">
        Coleccion completa
      </p>
      <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl leading-[0.95] text-dark">
        Todos nuestros amigurumis <span class="inline-block"></span>
      </h1>
      <p class="mx-auto mt-4 max-w-3xl text-base sm:text-lg leading-relaxed text-dark/75">
        Cada pieza esta tejida con mimo para acompanar momentos especiales y regalar ternura.
      </p>
    </header>

    <div class="mx-auto mt-12 w-full max-w-6xl grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {allProducts.map((product, index) => (
        <ProductCard product={product} index={index} variant="medium" />
      ))}
    </div>

    <div class="mx-auto mt-12 w-full max-w-2xl rounded-3xl border border-white/65 bg-white/70 p-6 text-center shadow-lg backdrop-blur-sm sm:p-8">
      <h2 class="text-3xl sm:text-4xl text-dark">No encuentras el modelo exacto?</h2>
      <p class="mt-3 text-dark/75">
        Escribenos y creamos un amigurumi personalizado para ti o para regalar.
      </p>
      <a
        href="https://wa.me/51934758261?text=Hola%20Knotty!%20Quiero%20cotizar%20un%20amigurumi%20personalizado%20🧸"
        target="_blank"
        rel="noreferrer"
        class="mt-6 inline-flex items-center rounded-full bg-primary px-8 py-3 text-sm sm:text-base font-semibold text-white shadow-lg shadow-primary/30 transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02] hover:bg-dark"
      >
        Pedir uno personalizado
      </a>
    </div>
  </section>
  <Footer />
</Layout>
